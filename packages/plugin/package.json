{
  "name": "hardhat-airsign",
  "version": "0.1.0",
  "description": "Hardhat plugin for remote transaction signing via browser wallet. Deploy contracts, run tasks, and execute scripts — no private keys in .env files.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "app-dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "bundle-app": "mv app-dist app-dist-old 2>/dev/null; cp -r ../app/dist app-dist && rm -rf app-dist-old",
    "prebuild:publish": "npm run build && npm run bundle-app",
    "clean": "rm -rf dist app-dist",
    "prepublishOnly": "npm run build && npm run bundle-app"
  },
  "keywords": [
    "hardhat",
    "hardhat-plugin",
    "ethereum",
    "smart-contracts",
    "metamask",
    "airsign",
    "walletconnect",
    "remote-signer",
    "browser-wallet",
    "deploy",
    "transaction-signing",
    "runner",
    "solidity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/harshitbwc/hardhat-airsign.git"
  },
  "homepage": "https://github.com/harshitbwc/hardhat-airsign#readme",
  "bugs": {
    "url": "https://github.com/harshitbwc/hardhat-airsign/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "ethers": "^5.0.0",
    "hardhat": "^2.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "ethers": "^5.7.2",
    "hardhat": "^2.19.0"
  },
  "overrides": {
    "engine.io": {
      "ws": {
        "bufferutil": "npm:@aspect-build/noop@1.0.0",
        "utf-8-validate": "npm:@aspect-build/noop@1.0.0"
      }
    }
  },
  "license": "MIT",
  "author": "Harshit Sharmaa <blockchainworld911@gmail.com>"
}
